{
  "name": "asset-optimizer",
  "version": "0.1.0",
  "description": "Desktop app for optimizing, converting, and batch-renaming image and video assets.",
  "main": "electron/main.cjs",
  "private": true,
  "author": "Fullermotion LLC",
  "homepage": "https://www.fullermotion.com",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@fontsource/inter": "^5.1.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.assetoptimizer.desktop",
    "productName": "Asset Optimizer",
    "copyright": "Copyright © 2026 Fullermotion LLC",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}
